{
  "name": "@openuidev/openclaw-ui-plugin",
  "version": "0.1.1",
  "description": "OpenClaw plugin that turns agent responses into Generative UI and serves the claw-client at /plugins/openui.",
  "license": "MIT",
  "homepage": "https://openui.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/thesysdev/openclaw-ui.git",
    "directory": "packages/claw-plugin"
  },
  "main": "./src/index.ts",
  "files": [
    "src",
    "static",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "generate": "tsx generate-prompt.ts",
    "bundle-ui": "cd ../claw-client && pnpm install --frozen-lockfile=false && pnpm build && rm -rf ../claw-plugin/static && cp -r out ../claw-plugin/static",
    "open": "node ../../scripts/open-ui.mjs",
    "lint:check": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format:check": "prettier --check ./src",
    "format:fix": "prettier --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "ci": "pnpm lint:check && pnpm format:check && pnpm typecheck"
  },
  "dependencies": {
    "@openuidev/lang-core": "^0.2.2"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  },
  "devDependencies": {
    "@openuidev/react-ui": "*",
    "@types/node": "^22.19.15",
    "openclaw": "*",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.12",
      "minGatewayVersion": "2026.4.12"
    }
  }
}
